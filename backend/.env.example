# Copy this file to `backend/.env` and fill in your own values.
# Do not commit the real `backend/.env` file to GitHub.

# Backend persistence
MONGO_URL=mongodb://localhost:27017
DB_NAME=crop_optimizer
USE_INMEMORY_DB=1

# Auth / API
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
CORS_ORIGINS=http://localhost:3000

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_RETRIES=2
USE_LLM_FORECAST=1

# External providers
NOAA_CDO_TOKEN=your_noaa_cdo_token
FRED_API_KEY=your_fred_api_key
USDA_NASS_API_KEY=your_usda_nass_api_key
ERS_API_KEY=your_ers_api_key

# Cost data
COSTS_API_URL=https://api.ers.usda.gov/data/arms/report?api_key=YOUR_ERS_API_KEY&year=2022&state=all&report=2
ERS_ARMS_YEAR=2022
ERS_ARMS_STATE=all
ERS_ARMS_REPORT=income statement
COSTS_BASE_YEAR=2022
COSTS_LAST_N_YEARS=3
COSTS_ALLOW_DEFAULT_FALLBACK=1
ERS_PER_FARM_TO_PER_ACRE_DIVISOR=1000

# Fetch / agent tuning
FORCE_LIVE_API_CALLS=1
AGENT_PROVIDER_MAX_WORKERS=2
AGENT_SKIP_FETCH_IF_DISCOVERY_EMPTY=0
NASS_DEFAULT_STATE=
NASS_DISCOVERY_MAX_CANDIDATES=6
NASS_FETCH_MAX_CANDIDATES=10

# Optional cache location
# CACHE_DIR=/absolute/path/to/cache
